  <script>
    function crearPaso(tag, tagClass, titulo, desc, link, linkLabel, delay) {
      const btn = link
        ? `<a href="${link}" target="_blank" rel="noopener" class="step-link">${linkLabel}</a>`
        : '';
      return `
        <div class="step" style="animation-delay:${delay}s">
          <span class="step-tag ${tagClass}">${tag}</span>
          <div class="step-title">${titulo}</div>
          <div class="step-desc">${desc}</div>
          ${btn}
        </div>`;
    }

    function procesarDiagnostico() {
      const laboral    = document.getElementById('q_laboral').value;
      const causa      = document.getElementById('q_causa').value;
      const parentesco = document.getElementById('q_parentesco').value;
      const hipoteca   = document.getElementById('q_hipoteca').checked;
      const tarjetas   = document.getElementById('q_tarjetas').checked;
      const auto       = document.getElementById('q_auto').checked;
      const retail     = document.getElementById('q_retail').checked;

      const relacionTexto = {
        conyuge: 'cónyuge o pareja',
        hijo: 'hijo/a',
        padre: 'padre o madre',
        heredero: 'heredero'
      }[parentesco];

      document.getElementById('form-section').classList.add('hidden');
      document.getElementById('results-section').classList.remove('hidden');

      let html = '';
      let d = 0;
      const step = 0.08;

      // SIEMPRE: SICS
      html += crearPaso(
        'Sistema SICS', 'tag-general',
        'Consulta de seguros — Conoce tu Seguro (CMF)',
        `El portal oficial de la CMF para buscar todos los seguros del fallecido. Como ${relacionTexto}, tienes interés legítimo para acceder con tu Clave Única. Este es siempre el primer paso.`,
        'https://www.conocetuseguro.cl', 'Ir a conocetuseguro.cl →', d
      ); d += step;

      // SIEMPRE: Deudas
      html += crearPaso(
        'Informe deudas', 'tag-deudas',
        'Informe de deudas financieras (CMF)',
        'Verifica todas las deudas activas del fallecido. Muchos seguros de desgravamen no se conocen hasta revisar este informe.',
        'https://www.cmfchile.cl/portal/principal/613/w3-propertyvalue-43331.html', 'Portal CMF →', d
      ); d += step;

      // AFP / SIS
      if (laboral === 'activo') {
        html += crearPaso(
          'AFP / SIS', 'tag-afp',
          'Seguro de Invalidez y Sobrevivencia (SIS)',
          'Al ser trabajador activo cotizando, el Seguro SIS financia pensiones de sobrevivencia para sus cargas. Gestiona directamente en la AFP del fallecido.',
          'https://www.spensiones.cl', 'Superintendencia de Pensiones →', d
        ); d += step;
      }

      if (laboral === 'jubilado') {
        html += crearPaso(
          'Pensión', 'tag-afp',
          'Pensión de sobrevivencia',
          'Los beneficiarios de un pensionado pueden tener derecho a pensión de viudez u orfandad. Contacta la AFP o entidad que pagaba la pensión.',
          'https://www.spensiones.cl', 'Superintendencia de Pensiones →', d
        ); d += step;
      }

      // SOAP
      if (causa === 'accidente') {
        html += crearPaso(
          'SOAP', 'tag-soap',
          'Seguro SOAP — hasta 300 UF por fallecimiento',
          'Tienes derecho a indemnización por muerte en accidente de tránsito. Identifica la póliza SOAP del vehículo involucrado usando su número de patente.',
          'https://www.bcn.cl/leychile/navegar?idNorma=30593', 'Ver normativa SOAP →', d
        ); d += step;
      }

      // Hipotecario
      if (hipoteca) {
        html += crearPaso(
          'Hipotecario', 'tag-hipoteca',
          'Desgravamen hipotecario',
          'El seguro debe pagar el saldo total del crédito. Detén los pagos de dividendo de inmediato y notifica al banco. Este seguro es obligatorio en todos los créditos hipotecarios.',
          null, null, d
        ); d += step;
      }

      // Consumo / tarjetas
      if (tarjetas || retail) {
        html += crearPaso(
          'Consumo / retail', 'tag-consumo',
          'Seguros de desgravamen en créditos de consumo',
          'Los créditos de consumo y tarjetas (bancarias y de retail) suelen incluir seguros que cubren el saldo adeudado. Solicita certificado de deuda a cada entidad y exige la cobertura.',
          null, null, d
        ); d += step;
      }

      // Automotriz
      if (auto) {
        html += crearPaso(
          'Automotriz', 'tag-consumo',
          'Desgravamen de crédito automotriz',
          'Verifica si el crédito del vehículo tenía seguro de desgravamen. Contacta la entidad financiera y solicita copia de la póliza asociada al crédito.',
          null, null, d
        ); d += step;
      }

      document.getElementById('lista-pasos').innerHTML = html;
      document.getElementById('diagnostico').scrollIntoView({ behavior: 'smooth' });
    }

    function reiniciar() {
      document.getElementById('results-section').classList.add('hidden');
      document.getElementById('form-section').classList.remove('hidden');
      document.getElementById('lista-pasos').innerHTML = '';
      document.getElementById('diagnostico').scrollIntoView({ behavior: 'smooth' });
    }
  </script>

</body>
</html>
